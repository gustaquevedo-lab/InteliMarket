# ==========================================
# InteliMarket — Variables de entorno
# ==========================================

# App
APP_NAME=InteliMarket
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=cambiar_en_produccion_64_chars_hexadecimal

# Base de datos
DATABASE_URL=postgresql+asyncpg://intelimarket:password@localhost:5432/intelimarket
DATABASE_SCHEMA=public
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_SECRET_KEY=cambiar_en_produccion_64_chars_hexadecimal
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# SIFEN
SIFEN_API_URL=https://ekuatia.set.gov.py/ekuatia/api
SIFEN_ENV=pruebas
SIFEN_CERT_PATH=
SIFEN_CERT_PASSWORD=

# Pasarelas de pago
PAGOPAR_API_KEY=
PAGOPAR_SECRET_KEY=
PAGOPAR_ENV=sandbox

KUAPAY_API_KEY=
KUAPAY_SECRET_KEY=
KUAPAY_ENV=sandbox

# BCP (tipos de cambio)
BCP_API_URL=https://www.bcp.gov.py/web_services/api/tipo-cambio-referencial
BCP_API_KEY=

# Intelicont (webhook)
INTELICONT_WEBHOOK_URL=https://api.intelicont.com/v1/integrations/intelimarket
INTELICONT_API_KEY=
INTELICONT_HMAC_SECRET=

# InteliAudit (webhook)
INTELIAUDIT_WEBHOOK_URL=https://api.inteliaudit.com/v1/integrations/intelimarket
INTELIAUDIT_API_KEY=
INTELIAUDIT_HMAC_SECRET=

# SueldOK (API)
SUELDOK_API_URL=https://api.sueldok.com
SUELDOK_API_KEY=

# Anthropic (IA)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Email (notificaciones)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@intelimarket.py

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
